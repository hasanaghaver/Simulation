@model List<GetToolVM>

@{
    int count = 0;
}

<div class="row">
    <div class="col-lg-12 grid-margin stretch-card">
        <div class="card">
            <div class="card-body">
                <h4 class="card-title">Tools Table</h4>
                <div class="table-responsive">
                    <a class="btn btn-outline-success" asp-action="create" >Create</a>
                    <table class="table table-striped">
                        <thead>
                            <tr>
                                <th>
                                    Count
                                </th>
                                <th>
                                    Image
                                </th>
                                <th>
                                    Title
                                </th>
                                <th>
                                    SubTitle
                                </th>
                                <th>
                                    Settings
                                </th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (GetToolVM tool in Model)
                            {
                                <tr>
                                    <td>
                                        @(++count)
                                    </td>
                                    <td class="py-1">
                                        <img src="~/assets/images/@tool.Image" alt="image" />
                                    </td>
                                    <td>
                                        @tool.Title
                                    </td>
                                    <td>
                                        @tool.SubTitle
                                    </td>
                                    <td>
                                        <a class="btn btn-outline-info" asp-action="detail" asp-route-id="@tool.Id">Detail</a>
                                        <a class="btn btn-outline-warning" asp-action="update" asp-route-id="@tool.Id">Update</a>
                                        <a class="btn btn-outline-danger" asp-action="delete" asp-route-id="@tool.Id">Delete</a>
                                    </td>
                                </tr>

                            }

                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
