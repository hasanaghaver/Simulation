@model LoginVm

<div style="height:100px"></div>
<div class="row">
    <div class="col-md-12 grid-margin stretch-card">
        <div class="card">
            <div class="card-body">
                <h4 class="card-title">Register</h4>
                <div class="text-danger" asp-validation-summary="ModelOnly"></div>
                <form class="forms-sample" method="post">
                    <div class="form-group">
                        <label asp-for="UsernameOrEmail">UsernameOrEmail</label>
                        <input asp-for="UsernameOrEmail" class="form-control" placeholder="UsernameOrEmail">
                        <span asp-validation-for="UsernameOrEmail" class="text-danger"></span>
                    </div>
                    <div class="form-group">
                        <label asp-for="Password">Password</label>
                        <input asp-for="Password" class="form-control" placeholder="Password">
                        <span asp-validation-for="Password" class="text-danger"></span>
                    </div>
                    <div class="form-group d-flex gap-2">
                        <label  asp-for="IsPersistent">Remember Me</label>
                        <input asp-for="IsPersistent" class="form-check">
                    </div>
                    <button type="submit" class="btn btn-primary me-2">Submit</button>
                    <a class="btn btn-light" asp-controller="home" asp-action="index">Cancel</a>
                </form>
            </div>
        </div>
    </div>
</div>

