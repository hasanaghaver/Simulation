@model LoginVm

<div style="width:auto; height:100px">
</div>
<div class="main-panel">
    <div class="content-wrapper">
        <div class="row">
            <div class="col-md-6 grid-margin stretch-card">
                <div class="card">
                    <div class="card-body">
                        <h4 class="card-title">Register</h4>
                        <div asp-validation-summary="ModelOnly"></div>
                        <form class="forms-sample" method="post">
                            <div class="form-group">
                                <label for="UsernameOrEmail">Username Or Email</label>
                                <input asp-for="UsernameOrEmail" class="form-control" placeholder="Username Or Email">
                                <span asp-validation-for="UsernameOrEmail"></span>
                            </div>
                            <div class="form-group">
                                <label for="Password">Password</label>
                                <input asp-for="Password" class="form-control" placeholder="Password">
                                <span asp-validation-for="Password"></span>
                            </div>
                            <div class="form-group">
                                <label for="IsPersistent">Remember Me</label>
                                <input asp-for="IsPersistent" class="form-check">
                            </div>
                            <button type="submit" class="btn btn-primary me-2">Submit</button>
                            <button class="btn btn-light" asp-controller="Home" asp-action="index">Cancel</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
