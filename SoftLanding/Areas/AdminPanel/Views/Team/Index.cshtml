@model List<GetMember>
@{
    int count = 0;
}

<div class="row">
    <div class="col-lg-12 grid-margin stretch-card">
        <div class="card">
            <div class="card-body">
                <a class="btn btn-success" asp-action="create">Create</a>
                <div class="table-responsive">
                    <table class="table table-striped">
                        <thead>
                            <tr>
                                <th>
                                    Count
                                </th>
                                <th>
                                    Image
                                </th>
                                <th>
                                    Name
                                </th>
                                <th>
                                    Job
                                </th>
                                <th>
                                    Settings
                                </th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (GetMember Member in Model)
                            {
                                <tr>
                                    <td>
                                        @(++count)
                                    </td>
                                    <td class="py-1">
                                        <img src="~/images/@Member.Image" alt="image" />
                                    </td>
                                    <td>
                                        @Member.Name
                                    </td>
                                    <td>
                                        @Member.Job
                                    </td>
                                    <td>
                                        <a class="btn btn-info" asp-action="Detail" asp-route-id="@Member.Id">Detail</a>
                                        <a class="btn btn-warning" asp-action="Update" asp-route-id="@Member.Id">Update</a>
                                        <a class="btn btn-danger" asp-action="Delete" asp-route-id="@Member.Id">Delete</a>
                                    </td>
                                </tr>
                            }

                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
