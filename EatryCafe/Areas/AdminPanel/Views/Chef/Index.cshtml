@model List<GetChefVM>

@{
    int count = 0;
}


<div class="row">
    <div class="col-lg-12 grid-margin stretch-card">
        <div class="card">
            <div class="card-body">
                <h4 class="card-title">Chefs</h4>
                </p>
                <div class="table-responsive">
                    <a class="btn btn-outline-success" asp-action="create">Create</a>

                    <table class="table table-striped">
                        <thead>
                            <tr>
                                <th>
                                    Count
                                </th>
                                <th>
                                    Image
                                </th>
                                <th>
                                    Name
                                </th>
                                <th>
                                    Job
                                </th>
                                <th>
                                    Settings
                                </th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (GetChefVM chef in Model)
                            {
                                <tr>
                                    <td>
                                        @(++count)
                                    </td>
                                    <td class="py-1">
                                        <img src="~/images/@chef.Image" alt="image" />
                                    </td>
                                    <td>
                                        @chef.Name
                                    </td>
                                    <td>
                                        @chef.Job
                                    </td>
                                    <td>
                                        <a class="btn btn-outline-info" asp-action="detail" asp-route-id="@chef.Id">Detail</a>
                                        <a class="btn btn-outline-warning" asp-action="update" asp-route-id="@chef.Id">Update</a>
                                        <a class="btn btn-outline-danger" asp-action="delete" asp-route-id="@chef.Id">Delete</a>
                                    </td>
                                    
                                </tr>

                            }
                           
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
