@model DetailJobVM



<div class="row">
    <div class="col-lg-12 grid-margin stretch-card">
        <div class="card">
            <div class="card-body">
                <h4 class="card-title">Job Detail</h4>

                <div class="table-responsive">
                    <table class="table table-striped">
                        <thead>
                            <tr>
                               
                                <th>
                                    Name
                                </th>
                               
                            </tr>
                        </thead>
                        <tbody>
                                <tr>
                                    
                                    <td>
                                        @Model.Name
                                    </td>
                                 
                                </tr>
                            

                        </tbody>
                    </table>

                </div>
                <a class="btn btn-close" asp-action="index"></a>
            </div>
        </div>
    </div>
</div>
