@model DetailTeamVm


<div class="row">
    <div class="col-lg-12 grid-margin stretch-card">
        <div class="card">
            <div class="card-body">
                <h4 class="card-title">Team Table</h4>
                <a class="btn btn-outline-success" asp-action="create">Create</a>

                <div class="table-responsive">
                    <table class="table table-striped">
                        <thead>
                            <tr>
                                <th>
                                    Image
                                </th>
                                <th>
                                    Name
                                </th>
                                <th>
                                    Job
                                </th>
                            </tr>
                        </thead>
                        <tbody>
                                <tr>
                                    <td class="py-1">
                                        <img src="~/images/@Model.Image" alt="image" />
                                    </td>
                                    <td>
                                        @Model.Name
                                    </td>
                                    <td>
                                        @Model.Job
                                    </td>
                                </tr>

                        </tbody>
                    </table>
                </div>
                    <a class="btn btn-close" asp-action="index"></a>
            </div>
        </div>
    </div>
</div>
